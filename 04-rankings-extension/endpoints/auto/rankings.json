{
    "getAll": {
        "description": "Gets all entries from 'rankings'",
        "route": "/rankings",
        "method": "GET",
        "sql": "SELECT * FROM rankings",
        "auth_required": false,
        "allowed_roles": [
            "*"
        ]
    },
    "getById": {
        "description": "Gets an entry from 'rankings' by its primary key",
        "route": "/rankings/$ranking_id",
        "method": "GET",
        "sql": "SELECT * FROM rankings WHERE ranking_id = $ranking_id",
        "auth_required": false,
        "allowed_roles": [
            "*"
        ]
    },
    "create": {
        "description": "Creates a new entry in 'rankings'",
        "route": "/rankings",
        "method": "POST",
        "sql": "INSERT INTO rankings (person_id, date, position) VALUES ($person_id, $date, $position)",
        "request_body_params": [
            "person_id",
            "date",
            "position"
        ],
        "auth_required": true,
        "allowed_roles": [
            "*"
        ]
    },
    "update": {
        "description": "Updates an existing entry in 'rankings' by its primary key",
        "route": "/rankings/$ranking_id",
        "method": "PUT",
        "sql": "UPDATE rankings SET person_id = $person_id, date = $date, position = $position WHERE ranking_id = $ranking_id",
        "request_body_params": [
            "person_id",
            "date",
            "position"
        ],
        "auth_required": true,
        "allowed_roles": [
            "*"
        ]
    },
    "delete": {
        "description": "Deletes an existing entry in 'rankings' by its primary key",
        "route": "/rankings/$ranking_id",
        "method": "DELETE",
        "sql": "DELETE FROM rankings WHERE ranking_id = $ranking_id",
        "auth_required": true,
        "allowed_roles": [
            "*"
        ]
    }
}